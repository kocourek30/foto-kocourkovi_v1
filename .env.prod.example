DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=0
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
ALLOWED_HOSTS=fotky.foto-kocourkovi.cz
CSRF_TRUSTED_ORIGINS=https://fotky.foto-kocourkovi.cz
USE_X_FORWARDED_HOST=1
SECURE_SSL_REDIRECT=1
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1
SECURE_HSTS_SECONDS=0

POSTGRES_DB=foto_kocourkovi
POSTGRES_USER=foto_kocourkovi
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

DEFAULT_FROM_EMAIL=no-reply@foto-kocourkovi.cz
ORDER_NOTIFICATION_EMAIL=info@foto-kocourkovi.cz
SITE_BRAND_NAME=Foto Kocourkovi
PHOTO_WATERMARK_TEXT=Foto Kocourkovi - NAHLED
PHOTO_WATERMARK_OPACITY=145
PHOTO_PREVIEW_MAX_SIZE=768
